{
  "name": "streamtune-backend",
  "version": "1.0.0",
  "description": "StreamTune backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "npx nodemon src/server.js",
    "test": "npx jest --runInBand",
    "seed": "node src/utils/seed.js"
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "config"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules",
      "uploads",
      "logs",
      "*.db"
    ],
    "delay": "500"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2",
    "sqlite3": "^5.1.7",
    "stripe": "^14.14.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.1.3"
  }
}
