{
  "name": "streamtune-backend",
  "version": "1.0.0",
  "description": "StreamTune backend",
  "main": "src/server.js",
  "scripts": {
    "start":   "node src/server.js",
    "dev":     "npx nodemon src/server.js",
    "test":    "npx jest --runInBand",
    "seed":    "node src/utils/seed.js",
    "migrate": "node src/utils/migrate.js"
  },
  "nodemonConfig": {
    "watch":  ["src", "config"],
    "ext":    "js,json",
    "ignore": ["node_modules", "uploads", "logs"],
    "delay":  "500"
  },
  "dependencies": {
    "express":            "^4.18.2",
    "ws":                 "^8.16.0",
    "sequelize":          "^6.35.2",
    "pg":                 "^8.11.3",
    "pg-hstore":          "^2.3.4",
    "bcryptjs":           "^2.4.3",
    "jsonwebtoken":       "^9.0.2",
    "dotenv":             "^16.4.1",
    "cors":               "^2.8.5",
    "helmet":             "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi":                "^17.11.0",
    "morgan":             "^1.10.0",
    "uuid":               "^9.0.0",
    "axios":              "^1.6.5",
    "stripe":             "^14.14.0",
    "winston":            "^3.11.0",
    "node-cron":          "^3.0.3",
    "compression":        "^1.7.4"
  },
  "devDependencies": {
    "nodemon":   "^3.0.3",
    "jest":      "^29.7.0",
    "supertest": "^7.1.3"
  }
}
