# ─── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Base de datos ──────────────────────────────────────────
# SQLite: no necesita instalación, se crea automáticamente
# El archivo streamtune.db se genera en la carpeta del proyecto
# No hay que cambiar nada aquí para desarrollo local

# ─── Redis (OPCIONAL) ───────────────────────────────────────
# Si no tienes Redis instalado, déjalo vacío o comenta la línea.
# El servidor usará memoria interna automáticamente.
# REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_en_produccion_minimo_32_caracteres_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=otro_secreto_diferente_minimo_32_caracteres
JWT_REFRESH_EXPIRES_IN=30d

# ─── YouTube Data API v3 (opcional) ─────────────────────────
# Sin API key funciona en modo dev con datos de ejemplo
# Para producción: https://console.cloud.google.com
# YOUTUBE_API_KEY=AIza...

# ─── Stripe (opcional) ──────────────────────────────────────
# Sin Stripe key, los créditos se otorgan directamente en dev
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Storage ────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_PRICE_PER_GB_MONTH=0.25

# ─── Créditos ───────────────────────────────────────────────
CREDIT_TO_USD_RATIO=0.01
CREATOR_REVENUE_SHARE=0.70
